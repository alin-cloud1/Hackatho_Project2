# ---- Server ----
PORT=4000
# Comma-separated list of allowed frontend origins for CORS.
CORS_ORIGIN=http://localhost:5173

# ---- Auth ----
# Change this to a long random string in production. Never commit the real value.
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=12h
# Salt mixed into roll numbers before hashing (anonymity pipeline). Keep secret.
ROLL_HASH_SALT=anti-kuddus-protocol-v1

# ---- Database (SQLite, built into Node — no server to install) ----
# Optional: override the database file location. Defaults to backend/data/anti_kuddus.db
# SQLITE_FILE=./data/anti_kuddus.db

# ---- Free RAG / LLM API ----
# Set ONE provider key. If both are set, Groq wins (override with LLM_PROVIDER).
# With no key, the syllabus + fact-check use a local heuristic fallback.
# LLM_PROVIDER=groq            # optional: force "groq" or "gemini"

# Option A — Groq (recommended: fast, easy, reliable free tier, no card).
#   Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Option B — Google Gemini (also has embeddings for semantic search).
#   Get a free key at https://aistudio.google.com/apikey  (looks like AIzaSy...)
GEMINI_API_KEY=
GEMINI_GEN_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=text-embedding-004
