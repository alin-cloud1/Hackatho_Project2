# ---- Server ----
PORT=4000
# Comma-separated list of allowed frontend origins for CORS.
CORS_ORIGIN=http://localhost:5173

# ---- Auth ----
# Change this to a long random string in production. Never commit the real value.
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=12h
# Salt mixed into roll numbers before hashing (anonymity pipeline). Keep secret.
ROLL_HASH_SALT=anti-kuddus-protocol-v1

# ---- Database (SQLite, built into Node — no server to install) ----
# Optional: override the database file location. Defaults to backend/data/anti_kuddus.db
# SQLITE_FILE=./data/anti_kuddus.db

# ---- Free RAG / LLM API (Google Gemini free tier) ----
# Get a free key at https://aistudio.google.com/apikey
# If left blank, the syllabus negotiator falls back to a local keyword filter.
GEMINI_API_KEY=
GEMINI_GEN_MODEL=gemini-1.5-flash
GEMINI_EMBED_MODEL=text-embedding-004
